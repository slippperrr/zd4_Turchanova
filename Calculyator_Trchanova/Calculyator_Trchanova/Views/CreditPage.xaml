<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Calculyator_Trchanova.Views.CreditPage"
             Title="Кредитный калькулятор">

    <ScrollView>
        <StackLayout Padding="20" Spacing="15">

            <Label Text="Кредитный калькулятор" StyleClass="header-label" />

            <Frame>
                <StackLayout Spacing="15">
                    <Label Text="Сумма кредита" FontAttributes="Bold" />
                    <Entry Text="{Binding Amount, Mode=TwoWay}" Keyboard="Numeric" Placeholder="Введите сумму в рублях" />

                    <Label Text="Срок кредита (месяцев)" FontAttributes="Bold" />
                    <Entry Text="{Binding Months, Mode=TwoWay}" Keyboard="Numeric" Placeholder="Введите количество месяцев" />

                    <Label Text="Тип платежа" FontAttributes="Bold" />
                    <Picker ItemsSource="{Binding PaymentTypes}" SelectedItem="{Binding SelectedPaymentType, Mode=TwoWay}" />

                    <StackLayout IsVisible="{Binding ShowGracePeriodSettings}">
                        <Label Text="Льготный период (месяцев)" FontAttributes="Bold" />
                        <Slider Minimum="0" Maximum="{Binding Months}" Value="{Binding GraceMonths, Mode=TwoWay}" />
                    </StackLayout>

                    <Label Text="Процентная ставка" FontAttributes="Bold" />
                    <Label Text="{Binding InterestRateText}" HorizontalOptions="Center" />
                    <Slider Minimum="0" Maximum="45" Value="{Binding InterestRate, Mode=TwoWay}" />

                </StackLayout>
            </Frame>

            <Frame BackgroundColor="#E8F5E9">
                <StackLayout Spacing="10">
                    <Label Text="РЕЗУЛЬТАТЫ" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="{Binding MonthlyPaymentDisplay}" StyleClass="result-label" />
                    <Label Text="{Binding TotalAmountDisplay}" FontSize="18" />
                    <Label Text="{Binding OverpaymentDisplay}" FontSize="18" />
                    <Label Text="{Binding InfoMessage}" FontSize="12" TextColor="Gray" />
                </StackLayout>
            </Frame>

        </StackLayout>
    </ScrollView>
</ContentPage>