<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Calculyator_Trchanova.Views.WelcomePage"
             Title="Добро пожаловать">

    <ScrollView>
        <StackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="Кредитный калькулятор" 
                   StyleClass="welcome-title" />

            <Frame>
                <StackLayout Spacing="15">
                    <Label Text="Username" 
                           FontSize="14" 
                           FontAttributes="Bold" />

                    <Entry x:Name="SurnameEntry" 
                           Placeholder="Введите вашу фамилию" 
                           Text=""
                           StyleClass="login-entry" />

                    <Label x:Name="ErrorLabel" 
                           Text="" 
                           TextColor="Red"
                           FontSize="12"
                           IsVisible="False" />
                </StackLayout>
            </Frame>

            <Button x:Name="SignInButton" 
                    Text="SIGN IN" 
                    StyleClass="signin-button"
                    Clicked="OnSignInClicked" />

        </StackLayout>
    </ScrollView>
</ContentPage>