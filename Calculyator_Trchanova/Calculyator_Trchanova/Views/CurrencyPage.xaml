<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Calculyator_Trchanova.Views.CurrencyPage"
             Title="Курсы валют">

    <ScrollView>
        <StackLayout Padding="20" Spacing="15">

            <Label Text="Курсы валют" StyleClass="header-label" />

            <Frame>
                <StackLayout Spacing="15">
                    <Label Text="Выберите дату" FontAttributes="Bold" />
                    <DatePicker Date="{Binding SelectedDate, Mode=TwoWay}" />
                    <Button Text="Получить курсы" Command="{Binding LoadRatesCommand}" />
                </StackLayout>
            </Frame>

            <Frame BackgroundColor="#E8F5E9">
                <StackLayout Spacing="15">
                    <Label Text="АКТУАЛЬНЫЕ КУРСЫ" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#1B5E20" />
                    <BoxView HeightRequest="1" BackgroundColor="#C8E6C9" />

                    <Label Text="Доллар США (USD)" />
                    <Label Text="{Binding USDRate}" StyleClass="result-label" />

                    <Label Text="Евро (EUR)" />
                    <Label Text="{Binding EURRate}" StyleClass="result-label" />

                    <Label Text="{Binding DateDisplay}" FontSize="14" TextColor="Gray" HorizontalOptions="Center" />

                    <ActivityIndicator IsVisible="{Binding IsLoading}" IsRunning="{Binding IsLoading}" Color="#4CAF50" />
                </StackLayout>
            </Frame>

            <Label Text="Центробанк РФ" FontSize="12" TextColor="#6D6D6D" HorizontalOptions="Center" />

        </StackLayout>
    </ScrollView>
</ContentPage>